FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

# System packages and Python 3.10 from Ubuntu repos
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    ca-certificates \
    cmake \
    build-essential \
    pkg-config \
    python3.10 \
    python3.10-dev \
    python3.10-venv \
    python3-pip \
 && rm -rf /var/lib/apt/lists/*

# Install uv (fast Python package manager)
RUN curl -LsSf https://astral.sh/uv/install.sh | sh

# Create and use a dedicated virtual environment for all Python packages
RUN python3.10 -m venv /opt/venv
ENV PATH="/opt/venv/bin:/root/.local/bin:${PATH}"

WORKDIR /workspace

# Copy only requirements to leverage Docker layer caching when you tweak them
COPY requirements.txt /tmp/requirements.txt

# Install latest PyTorch stack with CUDA support
RUN uv pip install \
    torch \
    torchvision \
    torchaudio \
    torch_geometric

# Install all Python dependencies from requirements
RUN uv pip install -r /tmp/requirements.txt

# Install pogema-toolbox without pulling its dependencies (e.g. wandb)
RUN uv pip install --no-deps "pogema-toolbox==0.1.1"

# Default command (override in `docker run` as needed)
CMD ["python"]